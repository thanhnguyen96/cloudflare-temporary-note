{
  "name": "note-24h",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "worker"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:worker": "npm --workspace worker run dev",
    "build": "npm run build:frontend && npm run build:worker",
    "build:frontend": "npm --workspace frontend run build",
    "build:worker": "npm --workspace worker run build",
    "typecheck": "npm --workspace frontend run typecheck && npm --workspace worker run typecheck",
    "deploy:all": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-all.ps1"
  }
}
