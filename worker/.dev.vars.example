# Worker local development variables
# Copy to .dev.vars when running `wrangler dev`.

ALLOWED_ORIGIN=*
MAX_TEXT_LENGTH=5000
MAX_FILE_BYTES=1073741824
R2_ACCOUNT_ID=REPLACE_WITH_CF_ACCOUNT_ID
R2_BUCKET_NAME=note-24h-files
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
